# A feltöltési mappában tilos PHP-t futtatni — biztonsági alapszabály
<FilesMatch "\.(php|phtml|phar|inc)$">
    Require all denied
</FilesMatch>

# Directory listing és CGI-futtatás letiltása
Options -Indexes -ExecCGI

# php_flag engine off csak akkor, ha mod_php használatban van
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
